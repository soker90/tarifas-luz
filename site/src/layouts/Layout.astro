---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Tarifas Luz — Compara y ahorra en tu factura de electricidad",
  description = "App de escritorio gratuita para comparar tarifas eléctricas del mercado libre en España. Calcula tu ahorro real con tus propias lecturas.",
} = Astro.props;

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0b0e11" />
    <link rel="icon" href={`${base}/favicon.svg`} type="image/svg+xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
  </head>
  <body>
    <slot />
  </body>
</html>
