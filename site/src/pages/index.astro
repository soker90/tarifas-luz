---
import { readFileSync } from "fs";
import { fileURLToPath } from "url";
import { resolve, dirname } from "path";
import Layout from "../layouts/Layout.astro";
import IconWindows from "../components/IconWindows.astro";
import IconApple from "../components/IconApple.astro";
import IconLinux from "../components/IconLinux.astro";
import AppLogo from "../components/AppLogo.astro";

const __dirname = dirname(fileURLToPath(import.meta.url));
const tauriConf = JSON.parse(
  readFileSync(resolve(__dirname, "../../../app/src-tauri/tauri.conf.json"), "utf-8")
);

const base    = import.meta.env.BASE_URL.replace(/\/$/, "");
const version = tauriConf.version;
const repo    = "soker90/tarifas-luz";
const releaseBase = `https://github.com/${repo}/releases/download/v${version}`;

const downloads = [
  {
    os: "Windows",
    Icon: IconWindows,
    arch: "x64",
    note: "Windows 10 / 11",
    primary: { label: "Setup .exe", url: `${releaseBase}/tarifas-luz_${version}_windows_x64-setup.exe` },
    alt:     { label: ".msi",       url: `${releaseBase}/tarifas-luz_${version}_windows_x64.msi` },
  },
  {
    os: "macOS",
    Icon: IconApple,
    arch: "Apple Silicon",
    note: "macOS 11+",
    primary: { label: "Apple Silicon .dmg", url: `${releaseBase}/tarifas-luz_${version}_macos_aarch64.dmg` },
    alt:     { label: "Intel .dmg",         url: `${releaseBase}/tarifas-luz_${version}_macos_x64.dmg` },
  },
  {
    os: "Linux",
    Icon: IconLinux,
    arch: "amd64",
    note: "Ubuntu / Debian",
    primary: { label: ".deb",      url: `${releaseBase}/tarifas-luz_${version}_linux_amd64.deb` },
    alt:     { label: ".AppImage", url: `${releaseBase}/tarifas-luz_${version}_linux_amd64.AppImage` },
  },
];

const features = [
  { n: "01", title: "Comparativa completa",  desc: "Todas las tarifas del mercado libre ordenadas de menor a mayor precio. Filtra por períodos (1P / 3P) y comercializadora." },
  { n: "02", title: "Cálculo con datos reales", desc: "Introduce los kWh punta, llano y valle de tus facturas y obtén el coste exacto con cada comercializadora, sin estimaciones." },
  { n: "03", title: "Varios suministros",    desc: "Gestiona casa, garaje, oficina o cualquier punto de suministro por separado desde la misma aplicación." },
  { n: "04", title: "Datos siempre frescos", desc: "La base de tarifas se actualiza automáticamente cada día. La app te avisa cuando hay una versión nueva disponible." },
  { n: "05", title: "Privacidad total",      desc: "Nada sale de tu dispositivo. Sin cuenta, sin telemetría, sin anuncios. Código abierto auditable en GitHub." },
];

const mockRows = [
  { name: "IMAGINA",       tariff: "Tarifa Base",      price: "0.099", saving: "−42 €",  best: true  },
  { name: "Doméstica",     tariff: "Luz Fijo 24h",     price: "0.102", saving: "−31 €",  best: false },
  { name: "ATULADO",       tariff: "Milenial",         price: "0.108", saving: "−19 €",  best: false },
  { name: "Naturgy",       tariff: "Noche",            price: "0.115", saving:  "+1 €",  best: false },
  { name: "Iberdrola",     tariff: "Plan Online",      price: "0.121", saving:  "+9 €",  best: false },
];
---

<Layout>

<!-- ─────────────────────────── NAV ─────────────────────────── -->
<header
  style="position:fixed;top:0;left:0;right:0;z-index:50;
         background:rgba(11,14,17,0.9);backdrop-filter:blur(12px);
         border-bottom:1px solid var(--color-hairline);"
>
  <div style="max-width:1200px;margin:0 auto;padding:0 20px;
              display:flex;align-items:center;justify-content:space-between;height:60px;">

    <a href={`${base}/`} style="display:flex;align-items:center;gap:10px;text-decoration:none;">
      <span style="display:flex;align-items:center;justify-content:center;
                   width:32px;height:32px;border-radius:var(--r-md);
                   background:var(--color-yellow);color:#181a20;font-size:16px;font-weight:700;">
        <AppLogo size={20} />
      </span>
      <span style="font-weight:600;font-size:15px;color:var(--color-white);">Tarifas Luz</span>
    </a>

    <nav style="display:flex;align-items:center;gap:6px;">
      <a href="#caracteristicas" style="padding:6px 12px;font-size:13px;font-weight:500;
                                        color:var(--color-muted);text-decoration:none;
                                        border-radius:var(--r-md);transition:color 0.15s;"
         onmouseover="this.style.color='var(--color-body)'" onmouseout="this.style.color='var(--color-muted)'">
        Características
      </a>
      <a href="#como-funciona" style="padding:6px 12px;font-size:13px;font-weight:500;
                                      color:var(--color-muted);text-decoration:none;
                                      border-radius:var(--r-md);transition:color 0.15s;"
         onmouseover="this.style.color='var(--color-body)'" onmouseout="this.style.color='var(--color-muted)'">
        Cómo funciona
      </a>
      <a href={`https://github.com/${repo}`} target="_blank" rel="noopener"
         style="display:flex;align-items:center;gap:6px;padding:6px 12px;font-size:13px;font-weight:500;
                color:var(--color-muted);text-decoration:none;border-radius:var(--r-md);transition:color 0.15s;"
         onmouseover="this.style.color='var(--color-body)'" onmouseout="this.style.color='var(--color-muted)'">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/>
        </svg>
        GitHub
      </a>
      <a href="#descargar"
         style="padding:8px 18px;border-radius:var(--r-md);
                background:var(--color-yellow);color:#181a20;
                font-size:13px;font-weight:700;text-decoration:none;
                transition:background 0.15s;"
         onmouseover="this.style.background='var(--color-yellow-active)'"
         onmouseout="this.style.background='var(--color-yellow)'">
        Descargar
      </a>
    </nav>
  </div>
</header>

<!-- ─────────────────────────── HERO ─────────────────────────── -->
<section style="padding:120px 20px 80px;max-width:1200px;margin:0 auto;">
  <div style="display:grid;grid-template-columns:1fr 1fr;gap:48px;align-items:center;">

    <!-- Texto izquierdo -->
    <div>
      <div class="anim section-label" style="margin-bottom:20px;">App gratuita · España</div>

      <h1 class="anim anim-1"
          style="font-size:clamp(2.4rem,4vw,3.5rem);font-weight:700;
                 line-height:1.1;letter-spacing:-1px;color:var(--color-white);
                 margin-bottom:20px;">
        Compara tarifas<br/>de luz y ahorra<br/>
        <span style="color:var(--color-yellow);">dinero real</span>
      </h1>

      <p class="anim anim-2"
         style="font-size:15px;line-height:1.65;color:var(--color-muted);
                max-width:420px;margin-bottom:36px;">
        Conecta tus facturas, introduce tus lecturas reales y descubre
        exactamente cuánto pagarías con cada comercializadora del mercado libre.
      </p>

      <div class="anim anim-3" style="display:flex;gap:10px;flex-wrap:wrap;margin-bottom:28px;">
        <a href="#descargar"
           style="display:inline-flex;align-items:center;gap:8px;
                  padding:12px 24px;border-radius:var(--r-md);
                  background:var(--color-yellow);color:#181a20;
                  font-size:14px;font-weight:700;text-decoration:none;
                  transition:background 0.15s;"
           onmouseover="this.style.background='var(--color-yellow-active)'"
           onmouseout="this.style.background='var(--color-yellow)'">
          <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/>
          </svg>
          Descargar gratis
        </a>
        <a href={`https://github.com/${repo}`} target="_blank" rel="noopener"
           style="display:inline-flex;align-items:center;gap:6px;
                  padding:12px 20px;border-radius:var(--r-md);
                  border:1px solid var(--color-hairline);
                  color:var(--color-body);font-size:14px;font-weight:500;text-decoration:none;
                  transition:border-color 0.15s;"
           onmouseover="this.style.borderColor='var(--color-strong)'"
           onmouseout="this.style.borderColor='var(--color-hairline)'">
          Ver código fuente
        </a>
      </div>

      <div class="anim anim-4" style="display:flex;gap:20px;">
        {([
          { Icon: IconWindows, label: "Windows" },
          { Icon: IconApple,   label: "macOS" },
          { Icon: IconLinux,   label: "Linux" },
        ] as const).map(({ Icon, label }) => (
          <div style="display:flex;align-items:center;gap:6px;font-size:12px;color:var(--color-muted);">
            <Icon size={15} color="var(--color-muted)" />
            {label}
          </div>
        ))}
      </div>
    </div>

    <!-- Mock derecho — tabla real de resultados -->
    <div class="anim anim-2"
         style="border-radius:var(--r-xl);border:1px solid var(--color-hairline);
                background:var(--color-card);overflow:hidden;">

      <!-- Cabecera del mock -->
      <div style="padding:14px 16px;border-bottom:1px solid var(--color-hairline);
                  display:flex;align-items:center;justify-content:space-between;">
        <div style="display:flex;align-items:center;gap:6px;">
          <span style="width:10px;height:10px;border-radius:50%;background:#ff5f57;display:inline-block;"></span>
          <span style="width:10px;height:10px;border-radius:50%;background:#febc2e;display:inline-block;"></span>
          <span style="width:10px;height:10px;border-radius:50%;background:#28c840;display:inline-block;"></span>
        </div>
        <span style="font-size:12px;color:var(--color-muted);">Comparativa · Casa Principal</span>
        <div style="width:50px;"></div>
      </div>

      <!-- Info suministro -->
      <div style="padding:12px 16px;border-bottom:1px solid var(--color-hairline);
                  display:flex;gap:16px;background:var(--color-raised);">
        <div>
          <div style="font-size:10px;color:var(--color-muted);text-transform:uppercase;letter-spacing:0.08em;margin-bottom:2px;">Potencia</div>
          <div style="font-size:13px;font-weight:600;color:var(--color-white);" class="num">4.6 / 4.6 kW</div>
        </div>
        <div>
          <div style="font-size:10px;color:var(--color-muted);text-transform:uppercase;letter-spacing:0.08em;margin-bottom:2px;">Consumo anual</div>
          <div style="font-size:13px;font-weight:600;color:var(--color-white);" class="num">3.240 kWh</div>
        </div>
        <div style="margin-left:auto;">
          <div style="font-size:10px;color:var(--color-muted);text-transform:uppercase;letter-spacing:0.08em;margin-bottom:2px;">18 tarifas</div>
          <div style="font-size:11px;color:var(--color-up);">actualizadas hoy</div>
        </div>
      </div>

      <!-- Cabeceras tabla -->
      <div style="display:grid;grid-template-columns:1fr auto auto;
                  padding:8px 16px;gap:12px;
                  font-size:10px;font-weight:600;letter-spacing:0.08em;
                  text-transform:uppercase;color:var(--color-muted);
                  border-bottom:1px solid var(--color-hairline);">
        <span>Comercializadora</span>
        <span style="text-align:right;">€/kWh</span>
        <span style="text-align:right;min-width:60px;">Ahorro / año</span>
      </div>

      <!-- Filas -->
      {mockRows.map((r, i) => (
        <div style={`display:grid;grid-template-columns:1fr auto auto;
                     padding:10px 16px;gap:12px;align-items:center;
                     border-bottom:1px solid var(--color-hairline);
                     background:${r.best ? "rgba(252,213,53,0.05)" : "transparent"};`}>
          <div style="display:flex;align-items:center;gap:8px;">
            <span style={`display:inline-flex;align-items:center;justify-content:center;
                          width:20px;height:20px;border-radius:3px;
                          font-size:10px;font-weight:700;
                          background:${r.best ? "var(--color-yellow)" : "var(--color-raised)"};
                          color:${r.best ? "#181a20" : "var(--color-muted)"};`}
                  class="num">{i+1}</span>
            <div>
              <div style={`font-size:13px;font-weight:600;color:${r.best ? "var(--color-white)" : "var(--color-body)"};`}>
                {r.name}
              </div>
              <div style="font-size:11px;color:var(--color-muted);">{r.tariff}</div>
            </div>
          </div>
          <div style="text-align:right;font-size:13px;font-weight:600;color:var(--color-white);" class="num">
            {r.price} €
          </div>
          <div style={`text-align:right;font-size:13px;font-weight:600;min-width:60px;
                       color:${r.saving.startsWith("−") ? "var(--color-up)" : "var(--color-muted)"};`}
               class="num">
            {r.saving}
          </div>
        </div>
      ))}

      <div style="padding:10px 16px;font-size:11px;color:var(--color-muted);text-align:center;">
        y 13 tarifas más →
      </div>
    </div>

  </div>
</section>

<!-- ──────────────────────── TICKER ──────────────────────── -->
<div style="border-top:1px solid var(--color-hairline);border-bottom:1px solid var(--color-hairline);
            overflow:hidden;padding:10px 0;">
  <div class="ticker-inner" style="display:flex;gap:48px;white-space:nowrap;">
    {Array.from({length: 2}).map(() =>
      ["18 tarifas comparadas","Actualización diaria","Windows · macOS · Linux",
       "0 datos enviados","Código abierto en GitHub","Instalador automático incluido",
       "Gratuito para siempre",`v${version} disponible ya`].map(t => (
        <span style="font-size:12px;font-weight:500;color:var(--color-muted);
                     display:inline-flex;align-items:center;gap:10px;">
          <span style="color:var(--color-yellow);font-size:8px;">◆</span>
          {t}
        </span>
      ))
    )}
  </div>
</div>

<!-- ─────────────────────── CARACTERÍSTICAS ──────────────────── -->
<section id="caracteristicas" style="padding:80px 20px;max-width:1200px;margin:0 auto;">

  <div style="display:flex;align-items:baseline;justify-content:space-between;
              border-bottom:1px solid var(--color-hairline);padding-bottom:20px;margin-bottom:0;">
    <h2 style="font-size:clamp(1.6rem,2.5vw,2rem);font-weight:700;letter-spacing:-0.5px;
               color:var(--color-white);">Características</h2>
    <span class="section-label">{features.length} funciones principales</span>
  </div>

  {features.map((f, i) => (
    <div class="card-hover"
         style={`display:grid;grid-template-columns:64px 1fr 1fr;gap:24px;align-items:start;
                 padding:24px 0;border-bottom:1px solid var(--color-hairline);
                 cursor:default;border-radius:0;`}>
      <span style="font-size:11px;font-weight:700;letter-spacing:0.08em;
                   color:var(--color-yellow);padding-top:3px;" class="num">{f.n}</span>
      <h3 style="font-size:15px;font-weight:600;color:var(--color-white);line-height:1.4;">
        {f.title}
      </h3>
      <p style="font-size:14px;color:var(--color-muted);line-height:1.6;">
        {f.desc}
      </p>
    </div>
  ))}
</section>

<!-- ─────────────────────── CÓMO FUNCIONA ──────────────────── -->
<section id="como-funciona"
         style="border-top:1px solid var(--color-hairline);
                border-bottom:1px solid var(--color-hairline);
                background:var(--color-card);
                padding:80px 20px;">
  <div style="max-width:1200px;margin:0 auto;">

    <div style="display:flex;align-items:baseline;justify-content:space-between;margin-bottom:48px;">
      <h2 style="font-size:clamp(1.6rem,2.5vw,2rem);font-weight:700;letter-spacing:-0.5px;
                 color:var(--color-white);">Cómo funciona</h2>
      <span class="section-label">3 pasos</span>
    </div>

    <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:1px;
                background:var(--color-hairline);border:1px solid var(--color-hairline);
                border-radius:var(--r-lg);overflow:hidden;">
      {[
        { n: "01", title: "Añade tu suministro", desc: "Introduce la potencia contratada (punta y valle) y los precios actuales de tu contrato, si los tienes a mano." },
        { n: "02", title: "Registra tus lecturas", desc: "Copia los kWh punta, llano y valle de cada factura. Cuantas más introduzcas, más precisa será la estimación." },
        { n: "03", title: "Ve tu ahorro exacto", desc: "La app calcula el coste con cada tarifa del mercado y te muestra ordenadas de menor a mayor, con el ahorro anual." },
      ].map(s => (
        <div style="background:var(--color-card);padding:32px 28px;">
          <div style="font-size:11px;font-weight:700;letter-spacing:0.1em;
                      color:var(--color-yellow);margin-bottom:16px;" class="num">{s.n}</div>
          <h3 style="font-size:16px;font-weight:600;color:var(--color-white);
                     margin-bottom:10px;line-height:1.35;">{s.title}</h3>
          <p style="font-size:13px;color:var(--color-muted);line-height:1.65;">{s.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ─────────────────────────── DESCARGA ──────────────────────── -->
<section id="descargar" style="padding:80px 20px;max-width:1200px;margin:0 auto;">

  <div style="display:flex;align-items:baseline;justify-content:space-between;
              border-bottom:1px solid var(--color-hairline);padding-bottom:20px;margin-bottom:40px;">
    <h2 style="font-size:clamp(1.6rem,2.5vw,2rem);font-weight:700;letter-spacing:-0.5px;
               color:var(--color-white);">Descarga</h2>
    <span class="section-label num">v{version} · gratis para siempre</span>
  </div>

  <!-- Tabla de descargas -->
  <div style="border:1px solid var(--color-hairline);border-radius:var(--r-lg);overflow:hidden;">
    {downloads.map((d, i) => (
      <div style={`display:grid;grid-template-columns:180px 1fr auto auto;gap:16px;
                   align-items:center;padding:20px 24px;
                   background:var(--color-card);
                   border-bottom:${i < downloads.length-1 ? "1px solid var(--color-hairline)" : "none"};`}>
        <!-- OS -->
        <div style="display:flex;align-items:center;gap:12px;">
          <d.Icon size={20} color="var(--color-muted)" />
          <div>
            <div style="font-size:15px;font-weight:600;color:var(--color-white);">{d.os}</div>
            <div style="font-size:12px;color:var(--color-muted);margin-top:2px;">{d.note} · {d.arch}</div>
          </div>
        </div>
        <!-- Info -->
        <div style="font-size:13px;color:var(--color-muted);">
          {d.primary.label} · {d.alt.label}
        </div>
        <!-- Alt link -->
        <a href={d.alt.url}
           style="padding:7px 14px;border-radius:var(--r-md);
                  border:1px solid var(--color-hairline);
                  font-size:12px;font-weight:500;color:var(--color-strong);
                  text-decoration:none;transition:border-color 0.15s;white-space:nowrap;"
           onmouseover="this.style.borderColor='var(--color-strong)'"
           onmouseout="this.style.borderColor='var(--color-hairline)'">
          {d.alt.label}
        </a>
        <!-- Primary download -->
        <a href={d.primary.url}
           style="display:inline-flex;align-items:center;gap:7px;
                  padding:9px 18px;border-radius:var(--r-md);
                  background:var(--color-yellow);color:#181a20;
                  font-size:13px;font-weight:700;text-decoration:none;
                  white-space:nowrap;transition:background 0.15s;"
           onmouseover="this.style.background='var(--color-yellow-active)'"
           onmouseout="this.style.background='var(--color-yellow)'">
          <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/>
          </svg>
          {d.primary.label}
        </a>
      </div>
    ))}
  </div>

  <p style="margin-top:16px;font-size:12px;color:var(--color-muted);text-align:center;">
    ¿Buscas otra arquitectura?
    <a href={`https://github.com/${repo}/releases/latest`} target="_blank" rel="noopener"
       style="color:var(--color-yellow);text-decoration:none;margin-left:4px;"
       onmouseover="this.style.textDecoration='underline'"
       onmouseout="this.style.textDecoration='none'">
      Ver todos los archivos en GitHub Releases →
    </a>
  </p>
</section>

<!-- ─────────────────────────── FOOTER ──────────────────────── -->
<footer style="border-top:1px solid var(--color-hairline);padding:32px 20px;">
  <div style="max-width:1200px;margin:0 auto;
              display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:16px;">

    <div style="display:flex;align-items:center;gap:10px;">
      <span style="display:flex;align-items:center;justify-content:center;
                   width:28px;height:28px;border-radius:var(--r-md);
                   background:var(--color-yellow);color:#181a20;font-size:14px;">
        <AppLogo size={18} />
      </span>
      <div>
        <div style="font-size:13px;font-weight:600;color:var(--color-white);">Tarifas Luz</div>
        <div style="font-size:11px;color:var(--color-muted);">MIT License · Open source</div>
      </div>
    </div>

    <div style="display:flex;gap:20px;flex-wrap:wrap;">
      {[
        { label: "GitHub", href: `https://github.com/${repo}` },
        { label: "Releases", href: `https://github.com/${repo}/releases` },
        { label: "Issues", href: `https://github.com/${repo}/issues` },
        { label: "Licencia", href: `https://github.com/${repo}/blob/master/LICENSE` },
      ].map(l => (
        <a href={l.href} target="_blank" rel="noopener"
           style="font-size:12px;color:var(--color-muted);text-decoration:none;transition:color 0.15s;"
           onmouseover="this.style.color='var(--color-body)'"
           onmouseout="this.style.color='var(--color-muted)'">{l.label}</a>
      ))}
    </div>

  </div>
  <div style="max-width:1200px;margin:16px auto 0;
              font-size:11px;color:var(--color-hairline);color:var(--color-raised);">
    Los precios mostrados son orientativos. Verifica siempre con tu comercializadora antes de contratar.
  </div>
</footer>

</Layout>
