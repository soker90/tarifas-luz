---
const steps = [
  {
    n: "01",
    title: "Añade tu suministro",
    desc: "Introduce la potencia contratada (punta y valle) y los precios actuales de tu contrato, si los tienes a mano.",
  },
  {
    n: "02",
    title: "Registra tus lecturas",
    desc: "Copia los kWh punta, llano y valle de cada factura. Cuantas más introduzcas, más precisa será la estimación.",
  },
  {
    n: "03",
    title: "Ve tu ahorro exacto",
    desc: "La app calcula el coste con cada tarifa del mercado y te muestra ordenadas de menor a mayor, con el ahorro anual.",
  },
];
---
<section id="como-funciona"
         style="border-top:1px solid var(--color-hairline);border-bottom:1px solid var(--color-hairline);
                background:var(--color-card);padding:80px 20px;">
  <div style="max-width:1200px;margin:0 auto;">

    <div style="display:flex;align-items:baseline;justify-content:space-between;margin-bottom:48px;">
      <h2 style="font-size:clamp(1.6rem,2.5vw,2rem);font-weight:700;letter-spacing:-0.5px;
                 color:var(--color-white);">Cómo funciona</h2>
      <span class="section-label">3 pasos</span>
    </div>

    <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:1px;
                background:var(--color-hairline);border:1px solid var(--color-hairline);
                border-radius:var(--r-lg);overflow:hidden;">
      {steps.map(s => (
        <div style="background:var(--color-card);padding:32px 28px;">
          <div class="num"
               style="font-size:11px;font-weight:700;letter-spacing:0.1em;
                      color:var(--color-yellow);margin-bottom:16px;">{s.n}</div>
          <h3 style="font-size:16px;font-weight:600;color:var(--color-white);
                     margin-bottom:10px;line-height:1.35;">{s.title}</h3>
          <p style="font-size:13px;color:var(--color-muted);line-height:1.65;">{s.desc}</p>
        </div>
      ))}
    </div>

  </div>
</section>
