---
interface Props {
  size?: number;
  color?: string;
}
const { size = 20, color = "currentColor" } = Astro.props;
---
<!-- Windows 4-pane flag — SVG propio, estilo Windows 11 flat -->
<svg
  width={size}
  height={size}
  viewBox="0 0 24 24"
  fill={color}
  xmlns="http://www.w3.org/2000/svg"
  aria-label="Windows"
>
